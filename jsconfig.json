{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*", "./src/*"]
    },
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["app/**/*", "src/**/*", "next-env.d.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
